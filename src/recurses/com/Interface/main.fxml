<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #2b1d12; -fx-border-color: #1a110a; -fx-border-width: 5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://www.w3.org/2000/fxml/1" fx:controller="com.Interface.MainController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="LIVRO DOS DRAGÕES" textFill="#e6c687">
                            <font>
                                <Font name="Georgia Bold" size="32.0" />
                            </font>
                        </Label>
                        <TextField fx:id="textId" editable="false" prefWidth="50.0" promptText="ID" style="-fx-background-color: #1a110a; -fx-text-fill: #e6c687; -fx-border-color: #8c6d4f; -fx-border-radius: 4; -fx-background-radius: 4; -fx-alignment: center;" visible="true">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </TextField>
                    </children>
                    <VBox.margin>
                        <Insets bottom="5.0" top="10.0" />
                    </VBox.margin>
                </HBox>

                <VBox spacing="12.0" style="-fx-background-color: #dfc8a5; -fx-background-radius: 8; -fx-border-color: #8c6d4f; -fx-border-width: 3; -fx-border-radius: 8;">
                    <children>
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label fx:id="lblEspecie" text="Espécie do Dragão:" textFill="#402915">
                                            <font>
                                                <Font name="Georgia Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="textEspecie" promptText="Ex: Fúria da Noite" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label fx:id="lblClasse" text="Classe (Mistério, Rocha, Brasa...):" textFill="#402915">
                                            <font>
                                                <Font name="Georgia Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="textClasse" promptText="Ex: Fornalha / Ataque" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label fx:id="lblDescricao" text="Descrição / Comportamento:" textFill="#402915">
                                            <font>
                                                <Font name="Georgia Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="textDescricao" promptText="Ex: Extremamente perigoso, cospe plasma..." style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label fx:id="lblEspecialidade" text="Especialidade / Habilidade Suprema:" textFill="#402915">
                                            <font>
                                                <Font name="Georgia Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="textEspecialidade" promptText="Ex: Camuflagem noturna" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>

                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Button fx:id="btnAdicionar" mnemonicParsing="false" onAction="#btnAdicionar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #4a5d4e; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #637a68; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Adicionar Dragão">
                            <font>
                                <Font name="Georgia Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#btnSalvar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #b58d3d; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #cfab5b; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Salvar Alterações">
                            <font>
                                <Font name="Georgia Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#btnBuscar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #7c2d23; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #9c3f34; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Deletar Dragão">
                            <font>
                                <Font name="Georgia Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnLimpar" mnemonicParsing="false" onAction="#btnLimpar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #5c534c; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #756b63; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Limpar Campos">
                            <font>
                                <Font name="Georgia Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tblLivroDosDragaos" onMouseClicked="#carregarCampos" prefHeight="300.0" style="-fx-background-color: #dfc8a5; -fx-border-color: #8c6d4f; -fx-border-width: 2; -fx-control-inner-background: #dfc8a5; -fx-control-inner-background-alt: #d4bc96;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colEspecie" prefWidth="180.0" text="Espécie" />
                        <TableColumn fx:id="colClasse" prefWidth="150.0" text="Classe" />
                        <TableColumn fx:id="colDescricao" prefWidth="300.0" text="Descrição" />
                        <TableColumn fx:id="colEspecialidade" prefWidth="170.0" text="Especialidade" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>