<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="680.0" prefWidth="900.0" style="-fx-background-color: #2b1d12; -fx-border-color: #1a110a; -fx-border-width: 5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://www.w3.org/2000/fxml/1" fx:controller="com.Interface.MainController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="LIVRO DOS DRAGÕES" textFill="#e6c687">
                            <font>
                                <Font name="Georgia Bold" size="32.0" />
                            </font>
                        </Label>
                        <TextField fx:id="textId" editable="false" prefWidth="50.0" promptText="ID" style="-fx-background-color: #1a110a; -fx-text-fill: #e6c687; -fx-border-color: #8c6d4f; -fx-border-radius: 4; -fx-background-radius: 4; -fx-alignment: center;">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </TextField>
                    </children>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </HBox>

                <Label fx:id="lblStatus" alignment="CENTER" prefHeight="20.0" prefWidth="600.0" text="Selecione ou catalogue um dragão..." textFill="#dfc8a5">
                    <font>
                        <Font name="Georgia Italic" size="14.0" />
                    </font>
                </Label>

                <VBox spacing="12.0" style="-fx-background-color: #dfc8a5; -fx-background-radius: 8; -fx-border-color: #8c6d4f; -fx-border-width: 3; -fx-border-radius: 8;">
                    <children>
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <HBox spacing="3.0">
                                            <children>
                                                <Label text="Espécie do Dragão" textFill="#402915"><font><Font name="Georgia Bold" size="14.0" /></font></Label>
                                                <Label text="*" textFill="#7c2d23"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <TextField fx:id="textEspecie" promptText="Ex: Fúria da Noite" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <HBox spacing="3.0">
                                            <children>
                                                <Label text="Classe" textFill="#402915"><font><Font name="Georgia Bold" size="14.0" /></font></Label>
                                                <Label text="*" textFill="#7c2d23"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <TextField fx:id="textClasse" promptText="Ex: Ataque / Rocha" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label text="Descrição / Comportamento:" textFill="#402915">
                                            <font><Font name="Georgia Bold" size="14.0" /></font>
                                        </Label>
                                        <TextField fx:id="textDescricao" promptText="Ex: Cospe plasma, camuflagem noturna..." style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="380.0" spacing="5.0">
                                    <children>
                                        <Label text="Especialidade Suprema:" textFill="#402915">
                                            <font><Font name="Georgia Bold" size="14.0" /></font>
                                        </Label>
                                        <TextField fx:id="textEspecialidade" promptText="Ex: Velocidade supersônica" style="-fx-background-color: #f5ebd6; -fx-border-color: #b39674; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #2b1d12;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                </VBox>

                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Button fx:id="btnAdicionar" mnemonicParsing="false" onAction="#btnAdicionar" onMouseEntered="#btnAdicionarHover" onMouseExited="#btnAdicionarExit" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #4a5d4e; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #637a68; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Adicionar Dragão">
                            <font><Font name="Georgia Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#btnSalvar" onMouseEntered="#btnSalvarHover" onMouseExited="#btnSalvarExit" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #b58d3d; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #cfab5b; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Salvar Alterações">
                            <font><Font name="Georgia Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#btnBuscar" onMouseEntered="#btnDeletarHover" onMouseExited="#btnDeletarExit" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #7c2d23; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #9c3f34; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Deletar Dragão">
                            <font><Font name="Georgia Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnLimpar" mnemonicParsing="false" onAction="#btnLimpar" onMouseEntered="#btnLimparHover" onMouseExited="#btnLimparExit" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #5c534c; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #756b63; -fx-border-radius: 20; -fx-border-width: 1.5;" text="Limpar Campos">
                            <font><Font name="Georgia Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tblLivroDosDragaos" onMouseClicked="#carregarCampos" prefHeight="260.0" style="-fx-background-color: #dfc8a5; -fx-border-color: #8c6d4f; -fx-border-width: 2; -fx-control-inner-background: #dfc8a5; -fx-control-inner-background-alt: #d4bc96;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" minWidth="50.0" maxWidth="50.0" text="ID" />
                        <TableColumn fx:id="colEspecie" prefWidth="180.0" minWidth="150.0" text="Espécie" />
                        <TableColumn fx:id="colClasse" prefWidth="140.0" minWidth="120.0" text="Classe" />
                        <TableColumn fx:id="colDescricao" prefWidth="310.0" minWidth="200.0" text="Descrição" />
                        <TableColumn fx:id="colEspecialidade" prefWidth="180.0" minWidth="130.0" text="Especialidade" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="lblContador" text="Total de Dragões Catalogados: 0" textFill="#e6c687">
                            <font>
                                <Font name="Georgia Bold" size="13.0" />
                            </font>
                            <HBox.margin>
                                <Insets right="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>